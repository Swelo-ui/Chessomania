<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:gravity="center_horizontal">

        <!-- Player Black (top) -->
        <LinearLayout
            android:id="@+id/player_black_box"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/player_box_bg"
            android:padding="8dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/avatar_black"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="♟"
                android:textColor="#161512"
                android:textSize="18sp"
                android:background="@drawable/avatar_light_bg" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="10dp">

                <TextView
                    android:id="@+id/name_black"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ChessOmania Engine"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Black"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/captures_black"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Status Bar -->
        <LinearLayout
            android:id="@+id/status_bar"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/status_bar_bg"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginBottom="6dp">

            <View
                android:id="@+id/status_dot"
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:background="@drawable/status_dot_bg"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="White to move"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <!-- Engine thinking indicator -->
            <ProgressBar
                android:id="@+id/engine_progress"
                style="?android:attr/progressBarStyleSmall"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginStart="8dp"
                android:indeterminateTint="@color/accent"
                android:visibility="gone" />

            <TextView
                android:id="@+id/engine_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Engine thinking..."
                android:textColor="@color/accent"
                android:textSize="11sp"
                android:layout_marginStart="4dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Chess Board View -->
        <com.chessomania.app.ui.ChessBoardView
            android:id="@+id/chess_board"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0"
            android:layout_marginBottom="6dp" />

        <!-- Board Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="8dp"
            android:paddingTop="4dp">

            <Button
                android:id="@+id/btn_flip"
                style="@style/Widget.Chessomania.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="⇅ Flip"
                android:textSize="11sp" />

            <Button
                android:id="@+id/btn_undo"
                style="@style/Widget.Chessomania.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="↩ Undo"
                android:textSize="11sp" />

            <Button
                android:id="@+id/btn_resign"
                style="@style/Widget.Chessomania.Button.Danger"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="⚑ Resign"
                android:textSize="11sp" />

            <Button
                android:id="@+id/btn_new_game"
                style="@style/Widget.Chessomania.Button.Primary"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="+ New"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Player White (bottom) -->
        <LinearLayout
            android:id="@+id/player_white_box"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/player_box_active_bg"
            android:padding="8dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="♟"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:background="@drawable/avatar_dark_bg" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="10dp">

                <TextView
                    android:id="@+id/name_white"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="You (White)"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="White pieces"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/captures_white"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Game Controls Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="12dp"
            android:layout_marginBottom="8dp">

            <!-- Game Mode -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GAME MODE"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <RadioGroup
                android:id="@+id/mode_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/mode_ai"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="vs AI"
                    android:textColor="@color/text_primary"
                    android:buttonTint="@color/accent"
                    android:checked="true"
                    android:textSize="12sp" />

                <RadioButton
                    android:id="@+id/mode_human"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="vs Human"
                    android:textColor="@color/text_primary"
                    android:buttonTint="@color/accent"
                    android:textSize="12sp" />

                <RadioButton
                    android:id="@+id/mode_friend"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="vs Friend"
                    android:textColor="@color/text_primary"
                    android:buttonTint="@color/accent"
                    android:textSize="12sp" />
            </RadioGroup>

            <!-- Difficulty Selector -->
            <TextView
                android:id="@+id/diff_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DIFFICULTY"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:id="@+id/diff_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/diff_easy"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="3dp"
                    android:text="Easy"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="@drawable/diff_btn_selected"
                    android:textColor="@color/white" />

                <TextView
                    android:id="@+id/diff_mid"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="3dp"
                    android:text="Mid"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="@drawable/diff_btn_normal"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/diff_hard"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="3dp"
                    android:text="Hard"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="@drawable/diff_btn_normal"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/diff_max"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:text="Max"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="@drawable/diff_btn_normal"
                    android:textColor="@color/text_primary" />
            </LinearLayout>
        </LinearLayout>

        <!-- Online Multiplayer & Friends Card -->
        <LinearLayout
            android:id="@+id/online_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="12dp"
            android:layout_marginBottom="8dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MULTIPLAYER &amp; FRIENDS"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="4dp" />
            
            <!-- Server Info Display -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <EditText
                    android:id="@+id/edit_server_url"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="36dp"
                    android:background="@drawable/card_bg"
                    android:hint="Server URL (e.g. http://192.168.1.5:3000)"
                    android:textColorHint="@color/text_secondary"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:singleLine="true"
                    android:textSize="12sp"
                    android:textColor="@color/text_primary"
                    android:inputType="textUri" />

                <Button
                    android:id="@+id/btn_save_server"
                    style="@style/Widget.Chessomania.Button.Primary"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="4dp"
                    android:text="Set IP"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Logged Out View -->
            <LinearLayout
                android:id="@+id/layout_logged_out"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <EditText
                    android:id="@+id/edit_username"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:background="@drawable/card_bg"
                    android:hint="Username"
                    android:textColorHint="@color/text_secondary"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:singleLine="true"
                    android:textSize="13sp"
                    android:textColor="@color/text_primary"
                    android:inputType="text"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/edit_password"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:background="@drawable/card_bg"
                    android:hint="Password"
                    android:textColorHint="@color/text_secondary"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:singleLine="true"
                    android:textSize="13sp"
                    android:textColor="@color/text_primary"
                    android:inputType="textPassword"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btn_login"
                        style="@style/Widget.Chessomania.Button.Primary"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:text="Login"
                        android:textSize="11sp" />

                    <Button
                        android:id="@+id/btn_register"
                        style="@style/Widget.Chessomania.Button.Secondary"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="Register"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Logged In View -->
            <LinearLayout
                android:id="@+id/layout_logged_in"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/text_logged_in_as"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Logged in as: User"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btn_friends_list"
                        style="@style/Widget.Chessomania.Button.Primary"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:text="👥 Friends"
                        android:textSize="11sp" />

                    <Button
                        android:id="@+id/btn_logout"
                        style="@style/Widget.Chessomania.Button.Danger"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="Logout"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Move History -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="MOVE HISTORY"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/btn_copy_history"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="4dp"
                    android:text="COPY"
                    android:textSize="10sp"
                    android:textColor="@color/accent"
                    android:textStyle="bold"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/move_history"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:nestedScrollingEnabled="true" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
