{
  "builds": [
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "^/index\\.html$",
      "dest": "public/chess/index.html"
    },
    {
      "src": "^/chessomania\\.apk$",
      "dest": "public/chess/chessomania.apk"
    },
    {
      "src": "^/$",
      "dest": "public/chess/index.html"
    },
    {
      "src": "^/(.*)$",
      "dest": "public/$1"
    }
  ]
}
